# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Drawbridge
.moat/
.claude/commands/

# Hero video frames + mp4s — kept on disk for Instagram posts but
# never deployed (large binaries, not referenced from public site)
public/cinematic/assets/frames-hero-*
public/cinematic/assets/hero-video-*.mp4
public/cinematic/assets/images/_gallery-backup-*
